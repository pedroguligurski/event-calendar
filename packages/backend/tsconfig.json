{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"rootDir": "src",
		"outDir": "dist",
		"declaration": false,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
