generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime? @default(now()) @db.Timestamp(6) @map("created_at")

  @@map("admins")
}

model User {
  id          Int       @id @default(autoincrement())
  name        String
  surname     String
  displayName String?   @map("display_name")
  email       String    @unique
  dateOfBirth DateTime? @db.Date @map("date_of_birth")
  createdAt   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  events      Event[]

  @@map("users")
}

model Event {
  id               Int            @id @default(autoincrement())
  startDateAndTime DateTime       @db.Timestamp(6) @map("start_date_and_time")
  endDateAndTime   DateTime       @db.Timestamp(6) @map("end_date_and_time")
  title            String
  resume           String?
  description      String?
  eventFormat      EventFormat    @map("event_format")
  transmissionLink String?        @map("transmission_link")
  ticketPrice      Decimal?       @default(0) @db.Decimal(10, 2) @map("ticket_price")
  ticketPlatform   String?        @map("ticket_platform")
  createdAt        DateTime?      @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt        DateTime?      @default(now()) @db.Timestamp(6) @map("updated_at")
  userId           Int            @map("user_id")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_events_user")
  eventToThemes    EventToTheme[]
  location         Location?
  speakers         Speaker[]

  @@map("events")
}

model EventToTheme {
  id      Int    @id @default(autoincrement())
  eventId Int    @map("event_id")
  themeId Int    @map("theme_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_event")
  theme   Theme  @relation(fields: [themeId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_theme")

  @@unique([eventId, themeId], map: "unique_event_theme")
  @@map("events_to_themes")
}

model Location {
  id           Int     @id @default(autoincrement())
  eventId      Int     @unique @map("event_id")
  localName    String  @map("local_name")
  zipCode      String? @map("zip_code")
  street       String?
  number       String?
  neighborhood String?
  complement   String?
  city         String
  state        String
  country      String
  event        Event   @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_location_event")

  @@map("locations")
}

model Speaker {
  id          Int     @id @default(autoincrement())
  name        String
  title       String?
  description String?
  image       String?
  social      String?
  affiliation String?
  eventId     Int     @map("event_id")
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_speaker_event")

  @@map("speakers")
}

model Theme {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  eventToThemes EventToTheme[]

  @@map("themes")
}

enum EventFormat {
  Online     @map("online")
  Presential @map("presential")
  Hybrid     @map("hybrid")

  @@map("event_format_enum")
}